<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:padding="8dp">

    <TextView
        android:id="@+id/pantalla"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="bottom|end"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="45sp"
        android:padding="16dp"
        android:maxLines="2" />

    <TableLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:stretchColumns="*">

        <TableRow>
            <Button android:id="@+id/btn_sin" android:text="sin" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_cos" android:text="cos" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_tan" android:text="tan" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_raiz" android:text="√" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn_pot" android:text="^" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_ln" android:text="ln" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_log" android:text="log" android:textColor="#00E676" android:background="#1E1E1E" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_c" android:text="C" android:textColor="#FF5252" android:background="#2D2D2D" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn_7" android:text="7" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_8" android:text="8" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_9" android:text="9" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_div" android:text="/" android:textColor="#FF9100" android:background="#1E1E1E" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn_4" android:text="4" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_5" android:text="5" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_6" android:text="6" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_mult" android:text="*" android:textColor="#FF9100" android:background="#1E1E1E" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn_1" android:text="1" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_2" android:text="2" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_3" android:text="3" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_menos" android:text="-" android:textColor="#FF9100" android:background="#1E1E1E" android:layout_margin="2dp"/>
        </TableRow>

        <TableRow>
            <Button android:id="@+id/btn_0" android:text="0" android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_punto" android:text="." android:textColor="#FFFFFF" android:background="#252525" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_igual" android:text="=" android:textColor="#FFFFFF" android:background="#FF9100" android:layout_margin="2dp"/>
            <Button android:id="@+id/btn_mas" android:text="+" android:textColor="#FF9100" android:background="#1E1E1E" android:layout_margin="2dp"/>
        </TableRow>
    </TableLayout>
</LinearLayout>
